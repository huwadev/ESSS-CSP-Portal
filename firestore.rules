rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All portal data — authenticated users only.
    // Role-based access (admin / manager / moderator / volunteer) and
    // account approval (pending screen) are enforced by the application.
    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else (unauthenticated access, other paths).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
