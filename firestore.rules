rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: returns true only if the calling user's account is approved (status == 'active')
    // This check runs on Firebase servers — it cannot be bypassed from the browser or API.
    function isApprovedUser(appId) {
      let hunterDoc = /databases/$(database)/documents/artifacts/$(appId)/public/data/hunters/$(request.auth.uid);
      return exists(hunterDoc) && get(hunterDoc).data.status == 'active';
    }

    match /artifacts/{appId}/public/data/{document=**} {

      // Any authenticated user can READ.
      // This is required so pending users can see their "waiting for approval" screen.
      allow read: if request.auth != null;

      // New users can CREATE their own hunter profile on first sign-in.
      // The document must belong to them and start as 'pending' — they cannot self-promote.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Only approved (active) users can WRITE/UPDATE/DELETE anything else.
      // Pending, suspended, or unapproved users are blocked here even if they bypass the UI.
      allow write: if request.auth != null && isApprovedUser(appId);
    }

    // Deny all other paths by default — belt-and-braces safety net.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
